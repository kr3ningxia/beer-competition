# Beer Competition System 本地环境变量模板

# 数据库
APP_DB_HOST=localhost
APP_DB_PORT=3306
APP_DB_NAME=beer_competition
APP_DB_USERNAME=root
APP_DB_PASSWORD=your_db_password

# Redis
APP_REDIS_HOST=localhost
APP_REDIS_PORT=6379
APP_REDIS_PASSWORD=
APP_REDIS_DATABASE=0
APP_REDIS_TIMEOUT=3s
APP_REDIS_CONNECT_TIMEOUT=3s
APP_REDIS_MAX_ACTIVE=16
APP_REDIS_MAX_IDLE=8
APP_REDIS_MIN_IDLE=1
APP_REDIS_MAX_WAIT=3s

# JWT
APP_JWT_SECRET=change-me-beer-competition-secret
APP_JWT_ADMIN_TTL=7200000
APP_JWT_PORTAL_TTL=7200000
APP_JWT_JUDGE_TTL=7200000
APP_JWT_ADMIN_REFRESH_TTL=43200000
APP_JWT_PORTAL_REFRESH_TTL=2592000000
APP_JWT_JUDGE_REFRESH_TTL=86400000

# 短信验证码
APP_SMS_CODE_TTL_MINUTES=5
APP_SMS_MOCK_ENABLED=true
APP_ALIYUN_ACCESS_KEY_ID=
APP_ALIYUN_ACCESS_KEY_SECRET=
APP_SMS_ENDPOINT=dypnsapi.aliyuncs.com
APP_SMS_SCHEME_NAME=默认方案
APP_SMS_SIGN_NAME=
APP_SMS_TEMPLATE_CODE=
APP_SMS_COUNTRY_CODE=86
APP_SMS_SEND_INTERVAL_SECONDS=60
APP_SMS_CODE_LENGTH=6
APP_SMS_CODE_TYPE=1
APP_SMS_DUPLICATE_POLICY=1

# 敏感信息加密与摘要
APP_PII_AES_KEY=dev-beer-competition-pii-aes-key-change-me
APP_PII_HASH_KEY=dev-beer-competition-pii-hash-key-change-me

# 文件存储
APP_STORAGE_PROVIDER=local
APP_STORAGE_LOCAL_DIR=uploads
APP_ALIOSS_ACCESS_KEY_ID=
APP_ALIOSS_ACCESS_KEY_SECRET=
APP_ALIOSS_BUCKET_NAME=
APP_ALIOSS_ENDPOINT=oss-cn-beijing.aliyuncs.com

# 前端接口地址
VITE_API_BASE_URL=http://localhost:8080

# 微信支付（正式启用时填写）
APP_WECHAT_PAY_MODE=MOCK
APP_WECHAT_PAY_APP_ID=
APP_WECHAT_PAY_MCH_ID=
APP_WECHAT_PAY_MERCHANT_SERIAL_NO=
APP_WECHAT_PAY_API_V3_KEY=
APP_WECHAT_PAY_PRIVATE_KEY_PATH=
APP_WECHAT_PAY_PUBLIC_KEY_ID=
APP_WECHAT_PAY_PUBLIC_KEY_PATH=
APP_WECHAT_PAY_NOTIFY_BASE_URL=
